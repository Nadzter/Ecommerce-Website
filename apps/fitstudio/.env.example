# --- Database (Neon Postgres) ---------------------------------------------
# Use the pooled connection string from Neon for runtime queries, and the
# direct connection string for migrations (set DIRECT_URL if your provider
# requires it).
DATABASE_URL="postgresql://user:password@host.neon.tech/fitstudio?sslmode=require"

# --- Clerk Authentication --------------------------------------------------
# Get these from https://dashboard.clerk.com after creating a Clerk app.
# Replace the REPLACE_ME placeholders with your own values.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
CLERK_SECRET_KEY="REPLACE_ME"

# Webhook signing secret issued when you register the /api/webhooks/clerk
# endpoint inside the Clerk dashboard.
CLERK_WEBHOOK_SECRET="whsec_REPLACE_ME"

# Clerk redirect paths (optional overrides).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# --- Stripe (Connect platform) --------------------------------------------
# Platform-level keys from https://dashboard.stripe.com — switch to live
# values in production.
STRIPE_SECRET_KEY="REPLACE_ME"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="REPLACE_ME"
# Webhook signing secret for the platform endpoint at /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET="REPLACE_ME"
# Stripe Connect Express OAuth client id (from Connect settings).
STRIPE_CONNECT_CLIENT_ID="REPLACE_ME"

# --- Cloudflare R2 (S3-compatible) ----------------------------------------
# Used to store generated invoice PDFs. The endpoint is the R2 bucket URL,
# e.g. https://<accountid>.r2.cloudflarestorage.com.
R2_ACCOUNT_ID="REPLACE_ME"
R2_ACCESS_KEY_ID="REPLACE_ME"
R2_SECRET_ACCESS_KEY="REPLACE_ME"
R2_BUCKET="fitstudio-invoices"
R2_PUBLIC_BASE_URL="https://invoices.fitstudio.app"

# --- Redis (BullMQ queue) -------------------------------------------------
# Standard rediss:// URL — for Upstash use the "Redis" tab in the console
# (NOT the REST URL). BullMQ needs a raw Redis protocol connection.
REDIS_URL="rediss://default:REPLACE_ME@us1-warm-puma-12345.upstash.io:6379"

# --- Twilio (WhatsApp) ----------------------------------------------------
TWILIO_ACCOUNT_SID="REPLACE_ME"
TWILIO_AUTH_TOKEN="REPLACE_ME"
# Sandbox or approved sender, formatted as "whatsapp:+14155238886".
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Signing secret Twilio uses to authenticate inbound webhook requests.
TWILIO_WEBHOOK_AUTH_TOKEN="REPLACE_ME"

# --- Resend (transactional email fallback) --------------------------------
RESEND_API_KEY="REPLACE_ME"
# Verified sender domain; format: "FitStudio <hello@fitstudio.app>".
RESEND_FROM="FitStudio <hello@fitstudio.app>"

# --- Anthropic (Claude chatbot) -------------------------------------------
ANTHROPIC_API_KEY="REPLACE_ME"

# --- Application -----------------------------------------------------------
# Root domain used to derive tenant subdomains in production
# (e.g. acme.fitstudio.app). In development the middleware falls back to
# the ?studio=<slug> query parameter so you can simulate tenants locally.
NEXT_PUBLIC_ROOT_DOMAIN="fitstudio.app"
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NODE_ENV="development"
