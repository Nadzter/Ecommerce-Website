# --- Database (Neon Postgres) ---------------------------------------------
# Use the pooled connection string from Neon for runtime queries, and the
# direct connection string for migrations (set DIRECT_URL if your provider
# requires it).
DATABASE_URL="postgresql://user:password@host.neon.tech/fitstudio?sslmode=require"

# --- Clerk Authentication --------------------------------------------------
# Get these from https://dashboard.clerk.com after creating a Clerk app.
# Replace the REPLACE_ME placeholders with your own values.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
CLERK_SECRET_KEY="REPLACE_ME"

# Webhook signing secret issued when you register the /api/webhooks/clerk
# endpoint inside the Clerk dashboard.
CLERK_WEBHOOK_SECRET="whsec_REPLACE_ME"

# Clerk redirect paths (optional overrides).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# --- Application -----------------------------------------------------------
# Root domain used to derive tenant subdomains in production
# (e.g. acme.fitstudio.app). In development the middleware falls back to
# the ?studio=<slug> query parameter so you can simulate tenants locally.
NEXT_PUBLIC_ROOT_DOMAIN="fitstudio.app"
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NODE_ENV="development"
