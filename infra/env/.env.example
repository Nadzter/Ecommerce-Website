# Copy to backend/.env for local development.

# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database ---
DATABASE_URL=postgresql://amwali:amwali_dev@localhost:5432/amwali_dev?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# 32+ chars. Rotate before any production deployment; see docs/adr/ for the
# planned migration to RS256 with JWKS.
JWT_SECRET=dev-secret-change-me-min-32-characters-long
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- OTP ---
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
# In dev we log the OTP instead of sending email/SMS.
OTP_DELIVERY=log

# --- Idempotency ---
IDEMPOTENCY_TTL_SECONDS=86400

# --- Provider ---
# 'mock' for Phase 1. Phase 2: 'lean', 'flutterwave'.
PROVIDER_OVERRIDE=mock
MOCK_WEBHOOK_SECRET=dev-mock-webhook-secret-change-me
MOCK_WEBHOOK_DELAY_MIN_MS=5000
MOCK_WEBHOOK_DELAY_MAX_MS=15000

# --- SCA thresholds (minor units) ---
# AED 500.00 = 50000 fils ; GHS 1500.00 = 150000 pesewas (≈ USD 100 each).
SCA_THRESHOLD_AED=50000
SCA_THRESHOLD_GHS=150000

# --- Reconciler ---
RECONCILER_POLL_SECONDS=60

# --- CORS ---
CORS_ORIGINS=http://localhost:3000
