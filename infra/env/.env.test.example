# Copy to backend/.env.test for the integration test suite.
# Tests boot an ephemeral Postgres schema; CI/dev should point at the same
# docker-compose Postgres but use a separate database name.

NODE_ENV=test
PORT=0
LOG_LEVEL=silent

DATABASE_URL=postgresql://amwali:amwali_dev@localhost:5432/amwali_test?schema=public
REDIS_URL=redis://localhost:6379/1

JWT_SECRET=test-secret-min-32-characters-test-test-test
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_DELIVERY=memory

IDEMPOTENCY_TTL_SECONDS=86400

PROVIDER_OVERRIDE=mock
MOCK_WEBHOOK_SECRET=test-mock-webhook-secret
MOCK_WEBHOOK_DELAY_MIN_MS=0
MOCK_WEBHOOK_DELAY_MAX_MS=0

SCA_THRESHOLD_AED=50000
SCA_THRESHOLD_GHS=150000

RECONCILER_POLL_SECONDS=60

CORS_ORIGINS=http://localhost:3000
