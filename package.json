{
  "name": "amwali",
  "version": "0.0.0",
  "private": true,
  "description": "Amwali — iOS keyboard-based payment initiation service. Monorepo root.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "pnpm -r --parallel lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "test": "pnpm -r --parallel test",
    "build": "pnpm -r build",
    "openapi:lint": "redocly lint shared/openapi/amwali.yaml",
    "openapi:generate": "pnpm --filter @amwali/shared-ts run generate",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:reset": "docker compose -f infra/docker-compose.yml down -v && docker compose -f infra/docker-compose.yml up -d"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0"
  }
}
