{
  "name": "@amwali/shared-ts",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript types generated from shared/openapi/amwali.yaml. Do not edit src/generated by hand.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./paths": "./src/generated/paths.ts"
  },
  "scripts": {
    "generate": "openapi-typescript ../openapi/amwali.yaml -o src/generated/paths.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.0"
  }
}
